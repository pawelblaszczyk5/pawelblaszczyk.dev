{
	"name": "pawelblaszczyk.dev",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"typecheck": "tsc",
		"format": "prettier \".\" --write",
		"verify-format": "prettier \".\" --check",
		"spellcheck": "cspell \"**\" --no-progress --relative",
		"update-dependencies": "taze major -I -w",
		"setup-swap": "esrun other/setup-swap.ts",
		"db:generate": "drizzle-kit generate:sqlite",
		"db:push": "drizzle-kit push:sqlite",
		"db:migrate": "esrun other/migrate.ts"
	},
	"dependencies": {
		"@digitak/esrun": "^3.2.24",
		"@paralleldrive/cuid2": "^2.2.1",
		"better-sqlite3": "^8.4.0",
		"drizzle-orm": "^0.27.0",
		"execa": "^7.1.1",
		"next": "canary",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"taze": "^0.10.2"
	},
	"devDependencies": {
		"@total-typescript/ts-reset": "^0.4.2",
		"@types/better-sqlite3": "^7.6.4",
		"@types/node": "^20.3.1",
		"@types/react": "^18.2.13",
		"@types/react-dom": "^18.2.6",
		"@typescript-eslint/eslint-plugin": "^5.60.0",
		"@typescript-eslint/parser": "^5.60.0",
		"cspell": "^6.31.1",
		"drizzle-kit": "^0.19.1",
		"eslint": "^8.43.0",
		"eslint-config-next": "^13.4.6",
		"eslint-config-prettier": "^8.8.0",
		"eslint-import-resolver-typescript": "^3.5.5",
		"eslint-plugin-canonical": "^4.2.2",
		"eslint-plugin-eslint-comments": "^3.2.0",
		"eslint-plugin-fp": "^2.3.0",
		"eslint-plugin-import": "^2.27.5",
		"eslint-plugin-jsx-a11y": "^6.7.1",
		"eslint-plugin-node": "^11.1.0",
		"eslint-plugin-perfectionist": "^1.4.0",
		"eslint-plugin-prefer-arrow-functions": "^3.1.4",
		"eslint-plugin-promise": "^6.1.1",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"eslint-plugin-react-refresh": "^0.4.1",
		"eslint-plugin-regexp": "^1.15.0",
		"eslint-plugin-storybook": "^0.6.12",
		"eslint-plugin-unicorn": "^47.0.0",
		"prettier": "^2.8.8",
		"typescript": "^5.1.3"
	},
	"packageManager": "pnpm@8.6.3"
}
