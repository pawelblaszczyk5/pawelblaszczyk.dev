{
	"name": "pawelblaszczyk.dev",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:storybook": "storybook dev -p 6006",
		"build": "vite build",
		"build:storybook": "storybook build",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"test:storybook": "test-storybook --browsers firefox chromium webkit",
		"preview": "vite preview",
		"start": "node build",
		"update-dependencies": "taze major -Iwi",
		"typecheck": "svelte-check",
		"lint": "eslint \".\" --fix",
		"verify-lint": "eslint \".\"",
		"format": "prettier --plugin-search-dir \".\" --write \".\"",
		"verify-format": "prettier --plugin-search-dir \".\" --check \".\"",
		"spellcheck": "cspell \"**\" --no-progress --relative",
		"setup-swap": "esrun other/setup-swap.ts",
		"db:generate": "drizzle-kit generate:sqlite",
		"db:push": "drizzle-kit push:sqlite",
		"db:migrate": "esrun other/migrate.ts",
		"prepare": "svelte-kit sync && panda codegen --clean"
	},
	"dependencies": {
		"@digitak/esrun": "^3.2.24",
		"better-sqlite3": "^8.4.0",
		"drizzle-orm": "^0.27.0",
		"execa": "^7.1.1"
	},
	"devDependencies": {
		"@pandacss/dev": "^0.5.1",
		"@paralleldrive/cuid2": "^2.2.1",
		"@playwright/test": "^1.35.1",
		"@storybook/addon-a11y": "^7.0.25",
		"@storybook/addon-essentials": "^7.0.25",
		"@storybook/addon-interactions": "^7.0.25",
		"@storybook/addon-links": "^7.0.25",
		"@storybook/blocks": "^7.0.25",
		"@storybook/svelte": "^7.0.25",
		"@storybook/sveltekit": "^7.0.25",
		"@storybook/test-runner": "^0.11.0",
		"@storybook/testing-library": "^0.2.0",
		"@sveltejs/adapter-node": "^1.3.0",
		"@sveltejs/kit": "^1.21.0",
		"@total-typescript/ts-reset": "^0.4.2",
		"@types/better-sqlite3": "^7.6.4",
		"@types/node": "^20.3.3",
		"@typescript-eslint/eslint-plugin": "^5.61.0",
		"@typescript-eslint/parser": "^5.61.0",
		"cspell": "^6.31.1",
		"drizzle-kit": "^0.19.3",
		"eslint": "^8.44.0",
		"eslint-config-prettier": "^8.8.0",
		"eslint-import-resolver-typescript": "^3.5.5",
		"eslint-plugin-canonical": "^4.2.2",
		"eslint-plugin-eslint-comments": "^3.2.0",
		"eslint-plugin-fp": "^2.3.0",
		"eslint-plugin-import": "^2.27.5",
		"eslint-plugin-node": "^11.1.0",
		"eslint-plugin-perfectionist": "^1.4.0",
		"eslint-plugin-prefer-arrow-functions": "^3.1.4",
		"eslint-plugin-promise": "^6.1.1",
		"eslint-plugin-regexp": "^1.15.0",
		"eslint-plugin-storybook": "^0.6.12",
		"eslint-plugin-svelte": "^2.32.2",
		"eslint-plugin-unicorn": "^47.0.0",
		"mdsvex": "^0.11.0",
		"prettier": "^2.8.8",
		"prettier-plugin-svelte": "^2.10.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"storybook": "^7.0.25",
		"svelte": "^4.0.3",
		"svelte-check": "^3.4.4",
		"sveltekit-superforms": "^1.1.3",
		"taze": "^0.11.2",
		"tslib": "^2.6.0",
		"type-fest": "^3.12.0",
		"typescript": "^5.1.6",
		"vite": "^4.3.9",
		"vitest": "^0.32.4",
		"zod": "^3.21.4"
	},
	"packageManager": "pnpm@8.6.6",
	"engines": {
		"node": "20.3.0",
		"pnpm": "8.6.6"
	},
	"engineStrict": true
}
