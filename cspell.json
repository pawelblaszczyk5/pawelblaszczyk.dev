{
	"$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
	"version": "0.2",
	"ignorePaths": ["pnpm-lock.yaml", ".git", ".gitignore", "other/drizzle/"],
	"dictionaries": ["lorem-ipsum"],
	"useGitignore": true,
	"words": [
		"Błaszczyk",
		"execa",
		"fallocate",
		"linebreak",
		"litefs",
		"overcommit",
		"Paweł",
		"pawelblaszczyk",
		"plusplus",
		"swapfile",
		"swapon",
		"taze",
		"tsbuildinfo",
		"typecheck",
		"typedefs",
		"flyio",
		"vercel",
		"paralleldrive",
		"digitak",
		"esrun"
	],
	"enableGlobDot": true
}
